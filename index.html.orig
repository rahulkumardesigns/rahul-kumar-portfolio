            <div class="client-logo">
                <img src="https://via.placeholder.com/150x80/9b59b6/ffffff?text=Akshardham" alt="Akshardham Temple">
            </div>
            <div class="client-logo">
                <img src="https://via.placeholder.com/150x80/2ecc71/ffffff?text=McDonald" alt="McDonald's">
