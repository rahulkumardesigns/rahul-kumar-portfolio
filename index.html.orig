<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rahul Kumar - Graphic Designer Portfolio</title>
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body>
    <!-- Particle Background for 3D Effect -->
    <div id="particles-js"></div>
    
    <!-- Navigation -->
    <nav>
        <div class="logo">RK</div>
        <ul class="nav-links">
            <li><a href="#home">Home</a></li>
            <li><a href="#about">About</a></li>
            <li><a href="#experience">Experience</a></li>
            <li><a href="#skills">Skills</a></li>
            <li><a href="#portfolio">Portfolio</a></li>
            <li><a href="#contact">Contact</a></li>
        </ul>
        <div class="hamburger">
            <span></span>
            <span></span>
            <span></span>
        </div>
    </nav>

    <!-- Home Section -->
    <section id="home" class="home-section">
        <div class="home-content">
            <h1>Hello, I'm <span class="highlight">Rahul Kumar</span></h1>
            <p class="subtitle">Creative Graphic Designer & Visual Artist</p>
            <div class="social-icons">
                <a href="#"><i class="fab fa-instagram"></i></a>
                <a href="#"><i class="fab behance"></i></a>
                <a href="#"><i class="fab fa-linkedin-in"></i></a>
                <a href="#"><i class="fab fa-dribbble"></i></a>
            </div>
            <a href="#portfolio" class="btn-primary">View My Work</a>
        </div>
        <div class="home-image">
            <div class="profile-3d-container">
                <div class="profile-3d">
                    <div class="profile-face front">RK</div>
                    <div class="profile-face back">Designer</div>
                    <div class="profile-face right">Creative</div>
                    <div class="profile-face left">Artist</div>
                    <div class="profile-face top">Vision</div>
                    <div class="profile-face bottom">Passion</div>
                </div>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="about-section">
        <div class="section-title">
            <h2>About Me</h2>
            <div></div>
        </div>
        <div class="about-content">
            <div class="about-text">
                <p>I'm a passionate graphic designer with extensive experience in creating visual solutions that communicate effectively and beautifully. My journey in design spans across print media, branding, and digital design, where I've honed my skills in transforming ideas into compelling visual narratives.</p>
                <p>With expertise in industry-standard tools like Adobe Creative Suite and CorelDRAW, I specialize in creating designs that not only look great but also serve strategic purposes - whether it's building brand identity, creating marketing materials, or designing packaging that stands out on shelves.</p>
                <p>Currently pursuing Fine Arts at IGNOU, I continuously update my skills and explore new creative horizons to bring fresh perspectives to every project I undertake.</p>
                <div class="about-info">
                    <div class="info-item">
                        <h3>Email</h3>
                        <p>rahul.krdesigns@gmail.com</p>
                    </div>
                    <div class="info-item">
                        <h3>Phone</h3>
                        <p>+91 8595474239</p>
                    </div>
                    <div class="info-item">
                        <h3>Location</h3>
                        <p>New Delhi, India</p>
                    </div>
                    <div class="info-item">
                        <h3>Availability</h3>
                        <p>Freelance & Full-time</p>
                    </div>
                </div>
            </div>
            <div class="about-image">
                <div class="image-3d-frame">
                    <div class="image-3d">
                        <div class="image-face front">
                            <img src="https://via.placeholder.com/400x500/3498db/ffffff?text=Rahul+Kumar" alt="Rahul Kumar">
                        </div>
                        <div class="image-face back">
                            <div class="back-content">
                                <h3>Creative Designer</h3>
                                <p>Expert in visual communication and brand storytelling through innovative design solutions.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Experience Section -->
    <section id="experience" class="experience-section">
        <div class="section-title">
            <h2>Professional Experience</h2>
            <div></div>
        </div>
        <div class="experience-timeline">
            <div class="timeline-item">
                <div class="timeline-content">
                    <h3>Creative Designer</h3>
                    <h4>Wonder Packaging</h4>
                    <p class="duration">2024 - Present</p>
                    <p>Specializing in packaging design including bites wrapping stickers, catalogues, menus, banners, posters, ribbons, and wallpaper designs. Creating visually appealing packaging solutions that enhance product appeal and brand recognition.</p>
                </div>
                <div class="timeline-dot"></div>
            </div>
            
            <div class="timeline-item">
                <div class="timeline-content">
                    <h3>Creative Designer</h3>
                    <h4>Paper Planet Design</h4>
                    <p class="duration">2023 - 2024</p>
                    <p>Focused on wallpaper design, stickers, catalogues, and interior decorative items. Created cohesive design collections for residential and commercial spaces.</p>
                </div>
                <div class="timeline-dot"></div>
            </div>
            
            <div class="timeline-item">
                <div class="timeline-content">
                    <h3>Creative Designer</h3>
                    <h4>Kalpataru</h4>
                    <p class="duration">2023</p>
                    <p>Specialized in ribbon design, hose sublimation printing, and design creation for textile applications.</p>
                </div>
                <div class="timeline-dot"></div>
            </div>
            
            <div class="timeline-item">
                <div class="timeline-content">
                    <h3>Creative Designer</h3>
                    <h4>Shri Kalka Printing Press</h4>
                    <p class="duration">2020 - 2022</p>
                    <p>Handled advertising design for multiple organizations, creating unique graphic designs for banners, posters, backdrops, unipoles, and various promotional materials.</p>
                </div>
                <div class="timeline-dot"></div>
            </div>
            
            <div class="timeline-item">
                <div class="timeline-content">
                    <h3>Designer</h3>
                    <h4>Pioneer Printing Solutions</h4>
                    <p class="duration">2019 - 2020</p>
                    <p>Worked on offset machine printing projects, handling designs and printing works for various commercial printing requirements.</p>
                </div>
                <div class="timeline-dot"></div>
            </div>
        </div>
    </section>

    <!-- Skills Section -->
    <section id="skills" class="skills-section">
        <div class="section-title">
            <h2>Technical Skills</h2>
            <div></div>
        </div>
        <div class="skills-grid">
            <div class="skill-category">
                <h3>Adobe Creative Suite</h3>
                <div class="skills-list">
                    <div class="skill-item">
                        <span>Adobe Illustrator</span>
                        <div class="skill-bar"><div class="skill-progress" style="width: 95%"></div></div>
                    </div>
                    <div class="skill-item">
                        <span>Adobe Photoshop</span>
                        <div class="skill-bar"><div class="skill-progress" style="width: 90%"></div></div>
                    </div>
                    <div class="skill-item">
                        <span>Adobe InDesign</span>
                        <div class="skill-bar"><div class="skill-progress" style="width: 85%"></div></div>
                    </div>
                    <div class="skill-item">
                        <span>Acrobat Reader</span>
                        <div class="skill-bar"><div class="skill-progress" style="width: 80%"></div></div>
                    </div>
                </div>
            </div>
            <div class="skill-category">
                <h3>Other Tools</h3>
                <div class="skills-list">
                    <div class="skill-item">
                        <span>CorelDRAW</span>
                        <div class="skill-bar"><div class="skill-progress" style="width: 90%"></div></div>
                    </div>
                    <div class="skill-item">
                        <span>Print Production</span>
                        <div class="skill-bar"><div class="skill-progress" style="width: 85%"></div></div>
                    </div>
                    <div class="skill-item">
                        <span>Typography</span>
                        <div class="skill-bar"><div class="skill-progress" style="width: 80%"></div></div>
                    </div>
                    <div class="skill-item">
                        <span>Color Theory</span>
                        <div class="skill-bar"><div class="skill-progress" style="width: 90%"></div></div>
                    </div>
                </div>
            </div>
            <div class="skill-category">
                <h3>Design Specialties</h3>
                <div class="skills-list">
                    <div class="skill-item">
                        <span>Branding & Identity</span>
                        <div class="skill-bar"><div class="skill-progress" style="width: 90%"></div></div>
                    </div>
                    <div class="skill-item">
                        <span>Packaging Design</span>
                        <div class="skill-bar"><div class="skill-progress" style="width: 85%"></div></div>
                    </div>
                    <div class="skill-item">
                        <span>Print Design</span>
                        <div class="skill-bar"><div class="skill-progress" style="width: 95%"></div></div>
                    </div>
                    <div class="skill-item">
                        <span>Digital Design</span>
                        <div class="skill-bar"><div class="skill-progress" style="width: 80%"></div></div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Portfolio Section -->
    <section id="portfolio" class="portfolio-section">
        <div class="section-title">
            <h2>My Portfolio</h2>
            <div></div>
        </div>
        <div class="portfolio-filters">
            <button class="filter-btn active" data-filter="all">All</button>
            <button class="filter-btn" data-filter="branding">Branding</button>
            <button class="filter-btn" data-filter="packaging">Packaging</button>
            <button class="filter-btn" data-filter="print">Print Design</button>
            <button class="filter-btn" data-filter="digital">Digital</button>
        </div>
        <div class="portfolio-grid">
            <!-- Portfolio Items -->
            <div class="portfolio-item" data-category="branding">
                <div class="portfolio-3d">
                    <div class="portfolio-face front">
                        <img src="https://via.placeholder.com/400x300/8e44ad/ffffff?text=Branding+Project+1" alt="Branding Project">
                        <div class="portfolio-overlay">
                            <h3>Brand Identity</h3>
                            <p>Complete brand identity system</p>
                        </div>
                    </div>
                    <div class="portfolio-face back">
                        <div class="portfolio-back-content">
                            <h3>Brand Identity Project</h3>
                            <p>Developed comprehensive brand identity including logo, color palette, typography, and brand guidelines for a startup in the food industry.</p>
                            <p><strong>Tools:</strong> Adobe Illustrator, Photoshop</p>
                        </div>
                    </div>
                    <div class="portfolio-face right">
                        <img src="https://via.placeholder.com/150x400/8e44ad/ffffff?text=Side+View" alt="Side View">
                    </div>
                    <div class="portfolio-face left">
                        <img src="https://via.placeholder.com/150x400/8e44ad/ffffff?text=Side+View" alt="Side View">
                    </div>
                    <div class="portfolio-face top">
                        <img src="https://via.placeholder.com/400x150/8e44ad/ffffff?text=Top+View" alt="Top View">
                    </div>
                    <div class="portfolio-face bottom">
                        <img src="https://via.placeholder.com/400x150/8e44ad/ffffff?text=Bottom+View" alt="Bottom View">
                    </div>
                </div>
            </div>
            
            <div class="portfolio-item" data-category="packaging">
                <div class="portfolio-3d">
                    <div class="portfolio-face front">
                        <img src="https://via.placeholder.com/400x300/e74c3c/ffffff?text=Packaging+Design+1" alt="Packaging Design">
                        <div class="portfolio-overlay">
                            <h3>Packaging Design</h3>
                            <p>Product packaging solution</p>
                        </div>
                    </div>
                    <div class="portfolio-face back">
                        <div class="portfolio-back-content">
                            <h3>Snack Food Packaging</h3>
                            <p>Created eye-catching packaging for healthy snack products with focus on shelf appeal and brand storytelling.</p>
                            <p><strong>Tools:</strong> Adobe Illustrator, Photoshop</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="portfolio-item" data-category="print">
                <div class="portfolio-3d">
                    <div class="portfolio-face front">
                        <img src="https://via.placeholder.com/400x300/f39c12/ffffff?text=Print+Design+1" alt="Print Design">
                        <div class="portfolio-overlay">
                            <h3>Print Design</h3>
                            <p>Marketing collateral</p>
                        </div>
                    </div>
                    <div class="portfolio-face back">
                        <div class="portfolio-back-content">
                            <h3>Marketing Campaign</h3>
                            <p>Designed comprehensive marketing materials including brochures, flyers, posters, and banners for a retail promotion.</p>
                            <p><strong>Tools:</strong> Adobe InDesign, Illustrator</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="portfolio-item" data-category="digital">
                <div class="portfolio-3d">
                    <div class="portfolio-face front">
                        <img src="https://via.placeholder.com/400x300/2ecc71/ffffff?text=Digital+Design+1" alt="Digital Design">
                        <div class="portfolio-overlay">
                            <h3>Digital Design</h3>
                            <p>Social media & web</p>
                        </div>
                    </div>
                    <div class="portfolio-face back">
                        <div class="portfolio-back-content">
                            <h3>Social Media Campaign</h3>
                            <p>Created engaging social media graphics and templates for brand promotion across multiple platforms.</p>
                            <p><strong>Tools:</strong> Adobe Photoshop, Illustrator</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <!-- More portfolio items -->
            <div class="portfolio-item" data-category="branding">
                <div class="portfolio-3d">
                    <div class="portfolio-face front">
                        <img src="https://via.placeholder.com/400x300/9b59b6/ffffff?text=Branding+Project+2" alt="Branding Project">
                        <div class="portfolio-overlay">
                            <h3>Branding</h3>
                            <p>Logo & identity</p>
                        </div>
                    </div>
                    <div class="portfolio-face back">
                        <div class="portfolio-back-content">
                            <h3>Corporate Branding</h3>
                            <p>Developed modern corporate identity for a technology consulting firm.</p>
                            <p><strong>Tools:</strong> Adobe Illustrator, InDesign</p>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="portfolio-item" data-category="packaging">
                <div class="portfolio-3d">
                    <div class="portfolio-face front">
                        <img src="https://via.placeholder.com/400x300/e67e22/ffffff?text=Packaging+Design+2" alt="Packaging Design">
                        <div class="portfolio-overlay">
                            <h3>Packaging</h3>
                            <p>Cosmetic packaging</p>
                        </div>
                    </div>
                    <div class="portfolio-face back">
                        <div class="portfolio-back-content">
                            <h3>Luxury Cosmetic Packaging</h3>
                            <p>Premium packaging design for skincare line with focus on elegance and premium feel.</p>
                            <p><strong>Tools:</strong> Adobe Illustrator, Photoshop</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Clients Section -->
    <section id="clients" class="clients-section">
        <div class="section-title">
            <h2>Trusted Clients</h2>
            <div></div>
        </div>
        <div class="clients-logos">
            <div class="client-logo">
                <img src="https://via.placeholder.com/150x80/3498db/ffffff?text=MakeMyTrip" alt="MakeMyTrip">
            </div>
            <div class="client-logo">
                <img src="https://via.placeholder.com/150x80/e74c3c/ffffff?text=Goibibo" alt="Goibibo">
            </div>
            <div class="client-logo">
                <img src="https://via.placeholder.com/150x80/f39c12/ffffff?text=RedBus" alt="RedBus">
